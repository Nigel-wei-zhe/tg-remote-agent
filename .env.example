# Telegram Bot 設定
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_ALLOWED_USER_ID=your_telegram_user_id   # 白名單，僅此 ID 可對話

# LLM 設定 (預設使用 MiniMax)
MINIMAX_API_KEY=your_minimax_api_key
MINIMAX_MODEL=MiniMax-M2.7                       # 可選
LLM_PROVIDER=minimax                             # 可選

# Agent 行為（可選）
AGENT_MAX_ROUNDS=5                               # 每則訊息最多 LLM/tool 互動輪數

# MiniMax 重試參數（可選）
MINIMAX_RETRY_MAX_ATTEMPTS=4                     # 總嘗試次數
MINIMAX_RETRY_BASE_MS=1500                       # 初始退避毫秒
MINIMAX_RETRY_MAX_MS=12000                       # 單次退避上限毫秒

# 工具限制（可選）
WRITE_FILE_MAX_BYTES=512000                      # write_file 內容上限（bytes）
READ_FILE_MAX_BYTES=20480                        # read_file 單次輸出上限（bytes）

# Session 記憶（可選）
SESSION_IDLE_TTL_MIN=30                          # idle 過期分鐘數
SESSION_COMPACT_TRIGGER_CHARS=12000              # 記憶注入 prompt 前的壓縮觸發字元數
MEMORY_DB_PATH=                                  # 記憶歷史 SQLite 路徑，空值預設 ~/.lazyhole/memory.sqlite
SQLITE_BIN=sqlite3                               # sqlite3 CLI 路徑

# 系統
PROJECT_ROOT=.                                   # 專案目錄
